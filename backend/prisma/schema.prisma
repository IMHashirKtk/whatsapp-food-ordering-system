generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id                String   @id @default(cuid())
  whatsappId        String   @unique
  name              String?

  state             ConversationState @default(IDLE)

  messages          Message[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Message {
  id          String   @id @default(cuid())

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  metaMessageId String @unique

  direction   MessageDirection
  type        MessageType

  content     String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum MessageDirection {
  INCOMING
  OUTGOING
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  STICKER
  REACTION
  BUTTON
  INTERACTIVE
  UNKNOWN
}

enum ConversationState {
  IDLE
  MAIN_MENU
  VIEWING_MENU
  ORDERING
  VIEWING_CART
  CHECKOUT
  TRACKING_ORDER
}